MCP_HOST=0.0.0.0
MCP_PORT=8000
# Publiczny URL serwera — wymagany przez OAuth redirect_uri
# Lokalnie: http://localhost:8000
# Produkcja: https://kajet.example.com
MCP_BASE_URL=http://localhost:8000
# Rola procesu: all (dev) | mcp (1 worker, stateful) | api (N workerów).
# W docker-compose ustawiane per usługa — tu zostaw all dla `uv run kajet-turbo`.
KAJET_ROLE=all
# API_WORKERS=2
